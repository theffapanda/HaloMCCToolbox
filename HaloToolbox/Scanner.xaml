<UserControl x:Class="HaloToolbox.Scanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="#C8D8E8"
             FontFamily="Consolas"
             FontSize="11"
             Background="#0A0C10">

    <UserControl.Resources>

        <!-- Flat button — matches HaloIntel's FlatButton style -->
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#2A3238"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#7D8590"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3A4248"/>
                                <Setter Property="Foreground"  Value="#C8D8E8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark text box -->
        <Style x:Key="DarkTB" TargetType="TextBox">
            <Setter Property="Background"      Value="#141820"/>
            <Setter Property="Foreground"      Value="#C8D8E8"/>
            <Setter Property="BorderBrush"     Value="#2A3238"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="CaretBrush"      Value="#C8D8E8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Padding="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- AUTO-LEAVE / REJOIN toggle style (shared) -->
        <Style x:Key="ToggleBtn" TargetType="ToggleButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#2A3238"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#484F58"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="Padding"         Value="8,3"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#3A4248"/>
                                <Setter Property="Foreground"  Value="#C8D8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Background="#0A0C10">
        <Grid.RowDefinitions>
            <RowDefinition Height="220" MinHeight="80"/>  <!-- Session Intel panel — resizable -->
            <RowDefinition Height="5"/>                   <!-- Drag splitter -->
            <RowDefinition Height="*"/>                   <!-- Proxy capture panel -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  SESSION INTEL  (always visible — shows captured lobby data)  -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="SessionIntelPanel"
                Grid.Row="0"
                Background="#1A1E24"
                BorderBrush="#2A3238"
                BorderThickness="0,0,0,1">
            <DockPanel>

                <!-- Header row -->
                <Grid DockPanel.Dock="Top" Margin="10,7,10,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>   <!-- ⬡ label -->
                        <ColumnDefinition Width="*"/>      <!-- hopper text -->
                        <ColumnDefinition Width="Auto"/>   <!-- 📋 RAW -->
                        <ColumnDefinition Width="Auto"/>   <!-- ✕ dismiss -->
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⬡" FontFamily="Consolas" FontSize="11" Foreground="#00C8FF"
                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                        <TextBlock Text="SESSION INTEL" FontFamily="Consolas" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#00C8FF" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="SessionHopperText" Grid.Column="1"
                               FontFamily="Consolas" FontSize="9" Foreground="#484F58"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>

                    <Button Grid.Column="2" Content="📋 RAW"
                            Style="{StaticResource FlatBtn}" FontSize="9"
                            Foreground="#7D8590" Margin="0,0,6,0"
                            ToolTip="Copy raw session JSON to clipboard for troubleshooting"
                            Click="SessionCopyRaw_Click"/>

                    <Button Grid.Column="3" Content="✕"
                            Style="{StaticResource FlatBtn}" FontSize="9" Padding="7,3"
                            ToolTip="Dismiss session intel"
                            Click="SessionClear_Click"/>
                </Grid>

                <!-- Alert banner — shown when stack/avoid detected -->
                <Border DockPanel.Dock="Top" x:Name="SessionAlertBanner"
                        Visibility="Collapsed"
                        Background="#BF3300"
                        CornerRadius="3"
                        Margin="8,0,8,6" Padding="10,6">
                    <TextBlock x:Name="SessionAlertText"
                               Foreground="White" FontWeight="SemiBold"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- Event log — timestamped detection history -->
                <Border DockPanel.Dock="Top" x:Name="SessionLogBorder"
                        Visibility="Collapsed"
                        Background="#0A0C10"
                        BorderBrush="#2A3238"
                        BorderThickness="0,0,0,1">
                    <ScrollViewer x:Name="SessionLogScroll"
                                  MaxHeight="90"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="SessionLogList" Padding="8,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas" FontSize="9"
                                               Foreground="#484F58" TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Column headers -->
                <Border DockPanel.Dock="Top" Background="#141820"
                        BorderBrush="#2A3238"
                        BorderThickness="0,1,0,1"
                        Padding="10,3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>    <!-- party dot -->
                            <ColumnDefinition Width="175"/>   <!-- gamertag -->
                            <ColumnDefinition Width="30"/>    <!-- team dot -->
                            <ColumnDefinition Width="100"/>   <!-- skill bar -->
                            <ColumnDefinition Width="55"/>    <!-- avg% -->
                            <ColumnDefinition Width="100"/>   <!-- range -->
                            <ColumnDefinition Width="*"/>     <!-- group sz -->
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="GAMERTAG" FontFamily="Consolas" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#484F58" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="TM" FontFamily="Consolas" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#484F58" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="SKILL" FontFamily="Consolas" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#484F58" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="AVG%" FontFamily="Consolas" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#484F58" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="5" Text="RANGE" FontFamily="Consolas" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#484F58" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="GRP" FontFamily="Consolas" FontSize="9"
                                   FontWeight="SemiBold" Foreground="#484F58" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Member rows — fills remaining height, drag the splitter to resize -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SessionMemberList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,5,10,5"
                                        BorderBrush="#2A3238"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="175"/>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="55"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Party colour dot -->
                                        <Ellipse Grid.Column="0" Width="8" Height="8"
                                                 Fill="{Binding PartyBrush}"
                                                 VerticalAlignment="Center"/>

                                        <!-- Gamertag -->
                                        <TextBlock Grid.Column="1" Text="{Binding Gamertag}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="#C8D8E8" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Team colour dot -->
                                        <Ellipse Grid.Column="2" Width="6" Height="6"
                                                 Fill="{Binding TeamBrush}"
                                                 VerticalAlignment="Center"/>

                                        <!-- Skill bar -->
                                        <Grid Grid.Column="3" Height="6"
                                              VerticalAlignment="Center" Margin="0,0,6,0">
                                            <Rectangle Fill="#2A3238" HorizontalAlignment="Stretch"
                                                       RadiusX="2" RadiusY="2"/>
                                            <Rectangle Fill="{Binding SkillBrush}" HorizontalAlignment="Left"
                                                       Width="{Binding SkillBarWidth}"
                                                       RadiusX="2" RadiusY="2"/>
                                        </Grid>

                                        <!-- Avg% -->
                                        <TextBlock Grid.Column="4" Text="{Binding AvgPctStr}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="{Binding SkillBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" Margin="0,0,6,0"/>

                                        <!-- Range -->
                                        <TextBlock Grid.Column="5" Text="{Binding RangeStr}"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="#7D8590" VerticalAlignment="Center"/>

                                        <!-- Party size -->
                                        <TextBlock Grid.Column="6" Text="{Binding PartySizeStr}"
                                                   FontFamily="Consolas" FontSize="9"
                                                   Foreground="{Binding PartyBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- Drag handle between Session Intel and Proxy panel -->
        <GridSplitter Grid.Row="1"
                      Height="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#2A3238"
                      Cursor="SizeNS"/>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  PROXY CAPTURE PANEL                                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#1A1E24"
                BorderBrush="#2A3238"
                BorderThickness="0,0,0,0">

            <DockPanel>

                <!-- ── Header bar — always visible ─────────────────────── -->
                <Border DockPanel.Dock="Top"
                        Background="#141820"
                        BorderBrush="#2A3238"
                        BorderThickness="0,0,0,1"
                        Padding="12,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- 0: label -->
                            <ColumnDefinition Width="Auto"/>   <!-- 1: status dot -->
                            <ColumnDefinition Width="Auto"/>   <!-- 2: status text -->
                            <ColumnDefinition Width="*"/>      <!-- 3: spacer -->
                            <ColumnDefinition Width="Auto"/>   <!-- 4: PORT label -->
                            <ColumnDefinition Width="58"/>     <!-- 5: port box -->
                            <ColumnDefinition Width="Auto"/>   <!-- 6: START/STOP toggle -->
                            <ColumnDefinition Width="Auto"/>   <!-- 7: EXTRACT TOKEN -->
                            <ColumnDefinition Width="Auto"/>   <!-- 8: JSON -->
                            <ColumnDefinition Width="Auto"/>   <!-- 9: CLEAR -->
                            <ColumnDefinition Width="Auto"/>   <!-- 10: SAVE ZIP -->
                            <ColumnDefinition Width="Auto"/>   <!-- 11: AUTO-LEAVE -->
                            <ColumnDefinition Width="Auto"/>   <!-- 12: TEST LEAVE -->
                            <ColumnDefinition Width="Auto"/>   <!-- 13: collapse -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="PROXY CAPTURE"
                                   FontFamily="Consolas" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#7D8590" VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                        <Ellipse x:Name="ProxyStatusDot"
                                 Grid.Column="1"
                                 Width="7" Height="7" Fill="#484F58"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>

                        <TextBlock x:Name="ProxyStatusText"
                                   Grid.Column="2"
                                   Text="STOPPED"
                                   FontFamily="Consolas" FontSize="9"
                                   Foreground="#7D8590"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <TextBlock Grid.Column="4" Text="PORT"
                                   FontFamily="Consolas" FontSize="9"
                                   Foreground="#484F58" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <TextBox x:Name="ProxyPortBox" Grid.Column="5"
                                 Text="8888" Style="{StaticResource DarkTB}"
                                 FontFamily="Consolas" FontSize="10"
                                 Padding="4,2" VerticalAlignment="Center"/>

                        <Button x:Name="ProxyToggleBtn" Grid.Column="6"
                                Content="▶  START PROXY"
                                Style="{StaticResource FlatBtn}"
                                Foreground="#00C8FF" BorderBrush="#00C8FF40"
                                Margin="6,0,4,0" FontSize="9"
                                Click="ProxyToggle_Click"/>

                        <Button Grid.Column="7"
                                Content="⚡ EXTRACT TOKEN"
                                Style="{StaticResource FlatBtn}"
                                Foreground="#D29922" BorderBrush="#D2992240"
                                Margin="0,0,4,0" FontSize="9"
                                Click="ProxyExtractToken_Click"
                                ToolTip="Scan captured traffic for x-343-authorization-spartan and copy to clipboard"/>

                        <Button Grid.Column="8"
                                Content="⎘ JSON"
                                Style="{StaticResource FlatBtn}"
                                Margin="0,0,4,0" FontSize="9"
                                Click="ProxyCopyJson_Click"
                                ToolTip="Copy response body of selected entry to clipboard"/>

                        <Button Grid.Column="9"
                                Content="✕ CLEAR"
                                Style="{StaticResource FlatBtn}"
                                Margin="0,0,4,0" FontSize="9"
                                Click="ProxyClear_Click"/>

                        <Button Grid.Column="10"
                                Content="⤓ SAVE ZIP"
                                Style="{StaticResource FlatBtn}"
                                Foreground="#00C8FF" BorderBrush="#00C8FF40"
                                Margin="0,0,4,0" FontSize="9"
                                ToolTip="Save all captured packets to a ZIP file for analysis"
                                Click="ProxySaveZip_Click"/>


                        <!-- AUTO-LEAVE toggle -->
                        <ToggleButton x:Name="AutoLeaveToggle"
                                      Grid.Column="11"
                                      Content="⊘ AUTO-LEAVE"
                                      FontSize="9" FontFamily="Consolas"
                                      Margin="0,0,4,0"
                                      ToolTip="Toggle to leave active ticket session"
                                      Checked="AutoLeaveToggle_Checked"
                                      Unchecked="AutoLeaveToggle_Unchecked">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleBtn}">
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Foreground"  Value="#F85149"/>
                                            <Setter Property="BorderBrush" Value="#F85149"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <Button Grid.Column="12"
                                Content="⊘ LEAVE NOW"
                                Style="{StaticResource FlatBtn}"
                                Foreground="#F85149" BorderBrush="#F8514940"
                                Margin="0,0,4,0" FontSize="9"
                                ToolTip="Immediately leave the current ticket session"
                                Click="TestLeave_Click"/>

                        <Button x:Name="ProxyCollapseBtn"
                                Grid.Column="13"
                                Content="▲"
                                Style="{StaticResource FlatBtn}"
                                FontSize="9" Padding="8,3"
                                Click="ProxyCollapseToggle_Click"/>
                    </Grid>
                </Border>

                <!-- ── Rejoin Guard strip ───────────────────────────────── -->
                <Border DockPanel.Dock="Top"
                        Background="#141820"
                        BorderBrush="#2A3238"
                        BorderThickness="0,0,0,1"
                        Padding="10,7">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- 0: label -->
                            <ColumnDefinition Width="*"/>      <!-- 1: status text -->
                            <ColumnDefinition Width="Auto"/>   <!-- 2: buttons -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="REJOIN GUARD"
                                   FontFamily="Consolas" FontSize="9" Foreground="#00C8FF"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>

                        <StackPanel Grid.Column="1" Orientation="Vertical"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="RejoinSessionText"
                                       Text="no session saved"
                                       FontFamily="Consolas" FontSize="9" Foreground="#7D8590"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="RejoinMatchText"
                                       Text=""
                                       FontFamily="Consolas" FontSize="9" Foreground="#00C8FF"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="RejoinStatusText"
                                       Text=""
                                       FontFamily="Consolas" FontSize="9" Foreground="#7D8590"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="RejoinCheckBtn"
                                    Content="CHECK" Click="RejoinCheck_Click"
                                    Style="{StaticResource FlatBtn}"
                                    IsEnabled="False"
                                    Padding="6,2" FontSize="9" Margin="0,0,4,0"/>
                            <Button x:Name="RejoinRestoreBtn"
                                    Content="RESTORE" Click="RejoinRestore_Click"
                                    Style="{StaticResource FlatBtn}"
                                    IsEnabled="False"
                                    Padding="6,2" FontSize="9" Margin="0,0,4,0"/>
                            <Button Content="CLEAR" Click="RejoinClear_Click"
                                    Style="{StaticResource FlatBtn}"
                                    Padding="6,2" FontSize="9" Margin="0,0,8,0"/>
                            <!-- Timestamp buttons for debugging -->
                            <Button Content="📍 LOG QUIT" Click="LogQuit_Click"
                                    Style="{StaticResource FlatBtn}"
                                    Padding="6,2" FontSize="9" Margin="0,0,4,0"
                                    ToolTip="Click when you close MCC"/>
                            <Button Content="📍 LOG REJOIN" Click="LogRejoin_Click"
                                    Style="{StaticResource FlatBtn}"
                                    Padding="6,2" FontSize="9"
                                    ToolTip="Click when you attempt rejoin"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Session Filters strip ─────────────────────────────── -->
                <Border DockPanel.Dock="Top"
                        Background="#0A0C10"
                        BorderBrush="#2A3238"
                        BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- MY GT label -->
                            <ColumnDefinition Width="150"/>    <!-- MyGamertagBox -->
                            <ColumnDefinition Width="16"/>     <!-- gap -->
                            <ColumnDefinition Width="Auto"/>   <!-- STACK ≥ label -->
                            <ColumnDefinition Width="40"/>     <!-- StackThresholdBox -->
                            <ColumnDefinition Width="16"/>     <!-- gap -->
                            <ColumnDefinition Width="Auto"/>   <!-- AVOID LIST label -->
                            <ColumnDefinition Width="*"/>      <!-- AvoidListBox -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="MY GT"
                                   FontFamily="Consolas" FontSize="9" Foreground="#7D8590"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="MyGamertagBox" Grid.Column="1"
                                 Style="{StaticResource DarkTB}" FontSize="10"
                                 VerticalAlignment="Center"
                                 ToolTip="Your gamertag — only the opposing team's parties are checked for stacks"/>

                        <TextBlock Grid.Column="3" Text="STACK ≥"
                                   FontFamily="Consolas" FontSize="9" Foreground="#7D8590"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="StackThresholdBox" Grid.Column="4"
                                 Text="4" Style="{StaticResource DarkTB}"
                                 FontSize="10" VerticalAlignment="Center"
                                 ToolTip="Minimum party size to trigger alert (default 4, minimum 2)"/>

                        <TextBlock Grid.Column="6" Text="AVOID LIST"
                                   FontFamily="Consolas" FontSize="9" Foreground="#7D8590"
                                   VerticalAlignment="Top" Margin="0,5,6,0"/>
                        <TextBox x:Name="AvoidListBox" Grid.Column="7"
                                 AcceptsReturn="True" TextWrapping="NoWrap"
                                 Height="52" VerticalScrollBarVisibility="Auto"
                                 Style="{StaticResource DarkTB}" FontSize="10"
                                 ToolTip="One gamertag per line — alert fires if any appear in the session"/>
                    </Grid>
                </Border>

                <!-- ── Tools bar: filter + hopper query ──────────────────── -->
                <Border DockPanel.Dock="Top"
                        Background="#0A0C10"
                        BorderBrush="#2A3238"
                        BorderThickness="0,0,0,1"
                        Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>   <!-- FILTER label -->
                            <ColumnDefinition Width="180"/>    <!-- ProxyFilterBox -->
                            <ColumnDefinition Width="Auto"/>   <!-- REJOIN toggle -->
                            <ColumnDefinition Width="*"/>      <!-- spacer -->
                            <ColumnDefinition Width="Auto"/>   <!-- HOPPER label -->
                            <ColumnDefinition Width="160"/>    <!-- HopperNameText -->
                            <ColumnDefinition Width="Auto"/>   <!-- QUERY button -->
                            <ColumnDefinition Width="Auto"/>   <!-- HopperResultText -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="FILTER" VerticalAlignment="Center"
                                   Foreground="#7D8590" FontSize="9"
                                   FontFamily="Consolas" Margin="0,0,6,0"/>
                        <TextBox x:Name="ProxyFilterBox" Grid.Column="1"
                                 Style="{StaticResource DarkTB}"
                                 FontFamily="Consolas" FontSize="10"
                                 ToolTip="Filter by host, method, or path"
                                 TextChanged="ProxyFilterBox_TextChanged"/>

                        <!-- REJOIN filter toggle -->
                        <ToggleButton x:Name="RejoinFilterToggle" Grid.Column="2"
                                      Content="REJOIN" Margin="6,0,0,0"
                                      ToolTip="Show only crash-rejoin diagnostic entries"
                                      Checked="RejoinFilterToggle_Changed"
                                      Unchecked="RejoinFilterToggle_Changed">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleBtn}">
                                    <Setter Property="FontSize" Value="9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Foreground"  Value="#00C8FF"/>
                                            <Setter Property="BorderBrush" Value="#00C8FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                        <TextBlock Grid.Column="4" Text="HOPPER" VerticalAlignment="Center"
                                   Foreground="#7D8590" FontSize="9"
                                   FontFamily="Consolas" Margin="0,0,6,0"/>
                        <TextBlock x:Name="HopperNameText" Grid.Column="5"
                                   Text="—" VerticalAlignment="Center"
                                   Foreground="#00C8FF" FontSize="10"
                                   FontFamily="Consolas"
                                   TextTrimming="CharacterEllipsis" Margin="0,0,8,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                        <Button x:Name="QueryHopperBtn" Grid.Column="6"
                                Content="QUERY" Click="QueryHopper_Click"
                                Style="{StaticResource FlatBtn}" Padding="6,2" FontSize="10"/>
                        <TextBlock x:Name="HopperResultText" Grid.Column="7"
                                   Text="" VerticalAlignment="Center"
                                   Foreground="#7D8590" FontSize="10"
                                   FontFamily="Consolas" Margin="8,0,0,0"/>
                    </Grid>
                </Border>

                <!-- ── WinHTTP note — shown when UAC elevation refused ──── -->
                <Border x:Name="ProxyWinHttpNote"
                        DockPanel.Dock="Bottom"
                        Visibility="Collapsed"
                        Background="#0D2018"
                        BorderBrush="#00C8FF40"
                        BorderThickness="0,1,0,0"
                        Padding="12,5">
                    <TextBlock FontFamily="Consolas" FontSize="9"
                               Foreground="#00C8FF" TextWrapping="Wrap">
                        <Run Text="To capture Halo MCC traffic, run as Administrator: "/>
                        <Run Text="netsh winhttp import proxy source=ie"
                             FontWeight="Bold" Foreground="#D29922"/>
                        <Run Text="  then restart the game."/>
                    </TextBlock>
                </Border>

                <!-- ── Collapsible traffic viewer ─────────────────────────── -->
                <Grid x:Name="ProxyPanelContent" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Capture list (ListView, newest first) -->
                    <ListView x:Name="ProxyCaptureList"
                              Grid.Column="0"
                              Background="#0A0C10"
                              Foreground="#C8D8E8"
                              BorderThickness="0"
                              SelectionChanged="ProxyCaptureList_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="TIME"   Width="72"
                                                DisplayMemberBinding="{Binding TimestampStr}"/>
                                <GridViewColumn Header="METHOD" Width="120"
                                                DisplayMemberBinding="{Binding Method}"/>
                                <GridViewColumn Header="STATUS" Width="48"
                                                DisplayMemberBinding="{Binding StatusDisplay}"/>
                                <GridViewColumn Header="HOST"   Width="140"
                                                DisplayMemberBinding="{Binding Host}"/>
                                <GridViewColumn Header="PATH"
                                                DisplayMemberBinding="{Binding Path}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Vertical splitter -->
                    <GridSplitter Grid.Column="1" Width="5"
                                  HorizontalAlignment="Stretch"
                                  Background="#2A3238"/>

                    <!-- Detail viewer -->
                    <DockPanel Grid.Column="2" Background="#0A0C10">
                        <TextBlock x:Name="ProxyDetailUrl"
                                   DockPanel.Dock="Top"
                                   FontFamily="Consolas" FontSize="10"
                                   Foreground="#00C8FF" TextWrapping="Wrap"
                                   Padding="8,5" Background="#141820"
                                   Text="Select an entry to view details"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox x:Name="ProxyDetailBody"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     AcceptsReturn="True"
                                     BorderThickness="0"
                                     FontFamily="Consolas" FontSize="10"
                                     Background="Transparent"
                                     Foreground="#C8D8E8"
                                     Padding="8,6"/>
                        </ScrollViewer>
                    </DockPanel>
                </Grid>

            </DockPanel>
        </Border>

    </Grid>
</UserControl>
