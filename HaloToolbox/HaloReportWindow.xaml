<Window x:Class="HaloToolbox.HaloReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Halo Support - Report a Player - Halo MCC Toolbox"
        Height="860" Width="1060"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        Background="#0A0C10">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#0F1318" BorderBrush="#1E2530"
                BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Reporting pill -->
                <Border Grid.Column="0" Background="#1A0000" BorderBrush="#FF2D55"
                        BorderThickness="1" CornerRadius="2" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="REPORTING  " FontFamily="Consolas" FontSize="10"
                                   Foreground="#FF2D55" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtSuspectPill" FontFamily="Consolas" FontSize="12"
                                   FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Nav URL -->
                <TextBlock Grid.Column="2" x:Name="TxtNavStatus" FontFamily="Consolas" FontSize="10"
                           Foreground="#4A5A6A" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" Text="Loading..."/>

                <!-- Re-fill button -->
                <Button Grid.Column="4" Content="Re-Fill Fields" Click="BtnFill_Click"
                        FontFamily="Consolas" FontSize="11"
                        Background="#0F1318" Foreground="#00C8FF"
                        BorderBrush="#1E2530" BorderThickness="1"
                        Padding="10,5" Cursor="Hand"/>

                <!-- Fill status -->
                <TextBlock Grid.Column="6" x:Name="TxtFillStatus" FontFamily="Consolas" FontSize="11"
                           Foreground="#4A5A6A" VerticalAlignment="Center"
                           MaxWidth="340" TextWrapping="Wrap" Text="Waiting for page..."/>
            </Grid>
        </Border>

        <!-- WebView2 -->
        <wv2:WebView2 Grid.Row="1" x:Name="WebView"/>

        <!-- Attach reminder bar -->
        <Border Grid.Row="2" Background="#0A1800" BorderBrush="#39FF14"
                BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="TxtAttachReminder"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="#39FF14" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Text="Build a Report ZIP first, then attach it to the form below."/>
                <Button Grid.Column="2" Content="Open ZIP Folder"
                        Click="BtnOpenFolder_Click"
                        FontFamily="Consolas" FontSize="11"
                        Background="#0A1800" Foreground="#39FF14"
                        BorderBrush="#39FF14" BorderThickness="1"
                        Padding="10,5" Cursor="Hand"/>
            </Grid>
        </Border>
    </Grid>
</Window>
