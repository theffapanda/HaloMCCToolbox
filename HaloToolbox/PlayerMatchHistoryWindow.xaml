<Window x:Class="HaloToolbox.PlayerMatchHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Match History"
        Width="880" Height="680"
        MinWidth="700" MinHeight="400"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Consolas"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"   Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground"   Value="{DynamicResource MutedBrush}"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"      Value="6,5"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextBrush}"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="0">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource StatsHoverRowBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Won}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MatchWinRowBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Won}" Value="False">
                    <Setter Property="Background" Value="{DynamicResource MatchLossRowBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Summary bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <StackPanel Margin="0,0,28,0" HorizontalAlignment="Center">
                    <TextBlock Text="MATCHES" Foreground="{DynamicResource MutedBrush}" FontSize="10"
                               FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="MatchesLabel" Text="—" Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,28,0" HorizontalAlignment="Center">
                    <TextBlock Text="WIN RATE" Foreground="{DynamicResource MutedBrush}" FontSize="10"
                               FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="WinRateLabel" Text="—" Foreground="{DynamicResource GreenBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,28,0" HorizontalAlignment="Center">
                    <TextBlock Text="K/D" Foreground="{DynamicResource MutedBrush}" FontSize="10"
                               FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="KdLabel" Text="—" Foreground="{DynamicResource AccentBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,28,0" HorizontalAlignment="Center">
                    <TextBlock Text="AVG KILLS" Foreground="{DynamicResource MutedBrush}" FontSize="10"
                               FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="AvgKillsLabel" Text="—" Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,28,0" HorizontalAlignment="Center">
                    <TextBlock Text="AVG DEATHS" Foreground="{DynamicResource MutedBrush}" FontSize="10"
                               FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="AvgDeathsLabel" Text="—" Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="AVG SCORE" Foreground="{DynamicResource MutedBrush}" FontSize="10"
                               FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="AvgScoreLabel" Text="—" Foreground="{DynamicResource TextBrush}"
                               FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ── Match table ───────────────────────────────────────────────────── -->
        <ListView x:Name="MatchList" Grid.Row="1" Margin="0">
            <ListView.View>
                <GridView>

                    <GridViewColumn Header="DATE" Width="148">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Date}" Foreground="{DynamicResource MutedBrush}"
                                           Padding="6,5" FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="GAME" Width="52">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Game}" Foreground="{DynamicResource TextBrush}"
                                           Padding="6,5" FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="TIME" Width="56">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Duration}" Foreground="{DynamicResource MutedBrush}"
                                           Padding="6,5" FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="RESULT" Width="56">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Result}" Foreground="{Binding ResultColor}"
                                           FontWeight="SemiBold" Padding="6,5" FontSize="11"
                                           FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="K" Width="38">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Kills}" Foreground="{DynamicResource TextBrush}"
                                           Padding="6,5" HorizontalAlignment="Right"
                                           FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="D" Width="38">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Deaths}" Foreground="{DynamicResource TextBrush}"
                                           Padding="6,5" HorizontalAlignment="Right"
                                           FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="K/D" Width="54">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding KD}" Foreground="{Binding KdColor}"
                                           FontWeight="SemiBold" Padding="6,5"
                                           HorizontalAlignment="Right"
                                           FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="ASSISTS" Width="58">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Assists}" Foreground="{DynamicResource MutedBrush}"
                                           Padding="6,5" HorizontalAlignment="Right"
                                           FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="HS" Width="38">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Headshots}" Foreground="{DynamicResource MutedBrush}"
                                           Padding="6,5" HorizontalAlignment="Right"
                                           FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="MEDALS" Width="58">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Medals}" Foreground="{DynamicResource MutedBrush}"
                                           Padding="6,5" HorizontalAlignment="Right"
                                           FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="SCORE" Width="58">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Score}" Foreground="{DynamicResource TextBrush}"
                                           Padding="6,5" HorizontalAlignment="Right"
                                           FontSize="11" FontFamily="Consolas"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Status bar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="12,6">
            <TextBlock x:Name="StatusText"
                       Text="Loading…"
                       Foreground="{DynamicResource MutedBrush}"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
