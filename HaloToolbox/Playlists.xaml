<UserControl x:Class="HaloToolbox.Playlists"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgBrush}"
             FontFamily="Consolas"
             FontSize="11"
             Foreground="{DynamicResource TextBrush}"
             Loaded="Playlists_Loaded">

    <UserControl.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7D8590"/>
            <Setter Property="BorderBrush" Value="#2A3238"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A4248"/>
                                <Setter Property="Foreground" Value="#C8D8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1E24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModeBtn" TargetType="Button" BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Padding" Value="14,7"/>
        </Style>

        <Style x:Key="ScheduleGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserReorderColumns" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <Style x:Key="ScheduleColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource PanelBrush}"/>
            <Setter Property="Foreground" Value="#89929C"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <Style x:Key="ScheduleCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="ScheduleRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{Binding RowBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="{Binding RowFontWeight}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1C2732"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock x:Name="TxtViewTitle"
                               Text="PLAYLISTS"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock x:Name="TxtHeaderSub"
                               Margin="0,4,0,0"
                               FontSize="10"
                               Foreground="{DynamicResource MutedBrush}"
                               Text="Browse live hopper composition or inspect weekly featured rotation history"/>
                </StackPanel>

                <Button x:Name="BtnRefresh"
                        DockPanel.Dock="Right"
                        Content="RELOAD XML"
                        Width="120"
                        Style="{StaticResource FlatBtn}"
                        Click="BtnRefresh_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnLiveComposer" Content="LIVE COMPOSER" Style="{StaticResource ModeBtn}" Click="BtnLiveComposer_Click"/>
                    <Button x:Name="BtnRotationSchedule" Content="ROTATION SCHEDULE" Style="{StaticResource ModeBtn}" Click="BtnRotationSchedule_Click" Margin="8,0,0,0"/>
                </StackPanel>

                <Grid x:Name="LiveControlsPanel" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MODE" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="BtnSocial" Content="SOCIAL" Style="{StaticResource ModeBtn}" Click="BtnSocial_Click"/>
                            <Button x:Name="BtnRanked" Content="RANKED" Style="{StaticResource ModeBtn}" Click="BtnRanked_Click" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="GAME SIZE" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboSize"
                                  Style="{StaticResource DarkCombo}"
                                  SelectionChanged="CboSize_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock x:Name="TxtSelectionLabel" Text="PLAYLIST" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboPlaylist"
                                  Style="{StaticResource DarkCombo}"
                                  SelectionChanged="CboPlaylist_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ScheduleControlsPanel" Margin="0,12,0,0" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="WEEK" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                        <DatePicker x:Name="DpRotationDate"
                                    SelectedDateChanged="DpRotationDate_SelectedDateChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="VIEW" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboScheduleFilter"
                                  Style="{StaticResource DarkCombo}"
                                  SelectionChanged="CboScheduleFilter_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="SEARCH" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CboScheduleSearch"
                                  Style="{StaticResource DarkCombo}"
                                  SelectionChanged="CboScheduleSearch_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="LOOKUP" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtScheduleHint"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Text="Jump to any week and inspect the featured playlists."/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="16,14,16,18">
            <Grid x:Name="LiveComposerView">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="CURRENT SELECTION" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock x:Name="TxtPlaylistName" Margin="0,8,0,0" FontSize="20" FontWeight="Bold" Text="No playlist selected"/>
                            <TextBlock x:Name="TxtPlaylistSubtitle" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="16"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="PLAYLIST STATS" FontSize="10" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Player Count" Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TxtPlayerCount" Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Grid.Row="1" Text="Max Party Size" Foreground="{DynamicResource TextBrush}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="TxtPartySize" Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="2" Text="Team Size" Foreground="{DynamicResource TextBrush}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtTeamSize" Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="3" Text="Entries Shown" Foreground="{DynamicResource TextBrush}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TxtEntryCount" Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="4" Text="Weight Total" Foreground="{DynamicResource TextBrush}" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="TxtWeightTotal" Foreground="{DynamicResource AccentBrush}" Margin="0,6,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="CATEGORY FILTERS" FontSize="10" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,10"/>
                            <TextBlock Text="GAMES INCLUDED" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                            <WrapPanel x:Name="GamePanel" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TxtCategoriesLabel" Text="GAME CATEGORIES INCLUDED" FontSize="9" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,6"/>
                            <WrapPanel x:Name="TagPanel"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="2">
                    <ScrollViewer Style="{StaticResource FlatScrollViewer}" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border x:Name="EmptyState"
                                    Background="{DynamicResource PanelBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Padding="24"
                                    Margin="0,0,0,12"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="TxtEmpty"
                                           Text="No playlist data loaded."
                                           Foreground="{DynamicResource MutedBrush}"
                                           TextAlignment="Center"/>
                            </Border>

                            <ItemsControl x:Name="GroupList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                                  Tag="{Binding TagId}"
                                                  Expanded="GroupExpander_Expanded"
                                                  Collapsed="GroupExpander_Collapsed"
                                                  Margin="0,0,0,12">
                                            <Expander.Header>
                                                <Border Background="{DynamicResource PanelBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="12,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       FontSize="12"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource TextBrush}"/>
                                                            <TextBlock Margin="0,3,0,0" Text="{Binding Subtitle}" FontSize="10" Foreground="{DynamicResource MutedBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center" FontSize="10" Foreground="{DynamicResource MutedBrush}" Text="{Binding HeaderSummary}"/>
                                                        <TextBlock Grid.Column="2" Margin="18,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Text="{Binding HeaderWeightDisplay}"/>
                                                    </Grid>
                                                </Border>
                                            </Expander.Header>

                                            <Border Background="{DynamicResource SurfaceBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="3"
                                                    Margin="0,6,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0"
                                                            Background="{DynamicResource SurfaceBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            Padding="12,7">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="90"/>
                                                                <ColumnDefinition Width="110"/>
                                                                <ColumnDefinition Width="2*" MinWidth="150"/>
                                                                <ColumnDefinition Width="1.35*" MinWidth="140"/>
                                                                <ColumnDefinition Width="90"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="GAME" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="WEIGHT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/>
                                                            <TextBlock Grid.Column="2" Text="SHARE" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/>
                                                            <TextBlock Grid.Column="3" Text="MAP" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/>
                                                            <TextBlock Grid.Column="4" Text="VARIANT" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/>
                                                            <TextBlock Grid.Column="5" Text="MODE" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource MutedBrush}"/>
                                                        </Grid>
                                                    </Border>

                                                    <ScrollViewer Grid.Row="1"
                                                                  Style="{StaticResource FlatScrollViewer}"
                                                                  VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  MaxHeight="360">
                                                        <ItemsControl ItemsSource="{Binding Entries}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                                                                        <Grid ClipToBounds="True">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="150"/>
                                                                                <ColumnDefinition Width="90"/>
                                                                                <ColumnDefinition Width="110"/>
                                                                                <ColumnDefinition Width="2*" MinWidth="150"/>
                                                                                <ColumnDefinition Width="1.35*" MinWidth="140"/>
                                                                                <ColumnDefinition Width="90"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <TextBlock Grid.Column="0" Text="{Binding GameDisplay}" Foreground="{Binding GameBrush}" TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Weight}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold"/>
                                                                            <TextBlock Grid.Column="2" Text="{Binding WeightShareDisplay}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                                                            <StackPanel Grid.Column="3" ClipToBounds="True">
                                                                                <TextBlock Text="{Binding MapDisplay}" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Text="{Binding MapId}" FontSize="9" Foreground="{DynamicResource MutedBrush}" Opacity="0.95" TextTrimming="CharacterEllipsis"/>
                                                                            </StackPanel>
                                                                            <TextBlock Grid.Column="4" Text="{Binding MapVariantDisplay}" Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                                                            <TextBlock Grid.Column="5" Text="{Binding CategoryDisplay}" Foreground="{DynamicResource AccentBrush}" TextTrimming="CharacterEllipsis"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Grid>
                                            </Border>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Grid x:Name="RotationScheduleView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Rows="1" Columns="4" Margin="0,0,0,14">
                    <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="CURRENT WEEK" FontSize="9" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock x:Name="TxtCurrentWeek" Margin="0,8,0,0" FontSize="16" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtNextReset" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="CURRENT SOCIAL" FontSize="9" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock x:Name="TxtCurrentSocial" Margin="0,8,0,0" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtCurrentSocialMeta" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="CURRENT RANKED 4V4" FontSize="9" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock x:Name="TxtCurrentRanked4v4" Margin="0,8,0,0" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtCurrentRanked4v4Meta" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Padding="14">
                        <StackPanel>
                            <TextBlock Text="CURRENT RANKED 2V2" FontSize="9" Foreground="{DynamicResource MutedBrush}"/>
                            <TextBlock x:Name="TxtCurrentRanked2v2" Margin="0,8,0,0" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="TxtCurrentRanked2v2Meta" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="ROTATION HISTORY" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                        <TextBlock x:Name="TxtConfirmedSummary" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}" Text="Recorded weekly featured rotations and forward-looking estimates."/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="GridConfirmedRotations"
                              Style="{StaticResource ScheduleGridStyle}"
                              ColumnHeaderStyle="{StaticResource ScheduleColumnHeaderStyle}"
                              CellStyle="{StaticResource ScheduleCellStyle}"
                              RowStyle="{StaticResource ScheduleRowStyle}"
                              MinRowHeight="32"
                              SelectionChanged="GridConfirmedRotations_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="DATE" Binding="{Binding DateDisplay}" Width="120"/>
                            <DataGridTextColumn Header="SOCIAL" Binding="{Binding SocialDisplay}" Width="*"/>
                            <DataGridTextColumn Header="RANKED 4V4" Binding="{Binding Ranked4v4Display}" Width="*"/>
                            <DataGridTextColumn Header="RANKED 2V2" Binding="{Binding Ranked2v2Display}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
