<Window x:Class="HaloToolbox.StatsAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Icon="Resources/halo_toolbox_whiteicon.ico"
        Title="Connect Halo Waypoint - HaloMCC Toolbox"
        Width="1100" Height="820"
        MinWidth="800" MinHeight="600"
        Background="#0A0C10"
        FontFamily="Consolas"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#080B0F" BorderBrush="#1E2530"
                BorderThickness="0,0,0,1" Padding="16,10">
            <StackPanel>
                <TextBlock Text="Connect Halo Waypoint"
                           Foreground="#00C8FF"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="Bold"/>
                <TextBlock Foreground="#4A5A6A" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0">
                    Sign in if prompted, then wait for your player profile to finish loading.
                    HaloMCC Toolbox captures the stats token automatically and closes this window.
                </TextBlock>
            </StackPanel>
        </Border>

        <wv2:WebView2 x:Name="Browser" Grid.Row="1"/>

        <Border Grid.Row="2" Background="#080B0F" BorderBrush="#1E2530"
                BorderThickness="0,1,0,0" Padding="16,8">
            <TextBlock x:Name="StatusText"
                       Text="Waiting for Halo Waypoint authentication..."
                       Foreground="#4A5A6A" FontFamily="Consolas" FontSize="11"/>
        </Border>
    </Grid>
</Window>
