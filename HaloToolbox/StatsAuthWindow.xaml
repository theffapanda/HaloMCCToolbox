<Window x:Class="HaloToolbox.StatsAuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Connect to Halo Waypoint — HaloMCC Toolbox"
        Width="1100" Height="820"
        MinWidth="800" MinHeight="600"
        Background="#0A0C10"
        FontFamily="Consolas"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#080B0F" BorderBrush="#1E2530"
                BorderThickness="0,0,0,1" Padding="16,10">
            <TextBlock Foreground="#4A5A6A" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap">
                Sign in to Halo Waypoint below. Your authorization token will be captured
                automatically once the page loads your stats — the window will close on its own.
                Your session is saved so future captures are instant.
            </TextBlock>
        </Border>

        <wv2:WebView2 x:Name="Browser" Grid.Row="1"/>

        <Border Grid.Row="2" Background="#080B0F" BorderBrush="#1E2530"
                BorderThickness="0,1,0,0" Padding="16,8">
            <TextBlock x:Name="StatusText"
                       Text="Waiting for Halo Waypoint authentication…"
                       Foreground="#4A5A6A" FontFamily="Consolas" FontSize="11"/>
        </Border>
    </Grid>
</Window>
